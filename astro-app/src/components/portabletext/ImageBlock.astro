---
import { urlFor } from "../../utils/image";

interface Props {
  node: {
    _type: "image";
    _key?: string;
    alt?: string;
    asset: {
      _type: "reference";
      _ref: string;
    };
  };
}

const { node } = Astro.props;
const imageUrl = urlFor(node).width(800).auto("format").url();
---

<figure class="post-image my-8" style="max-width: 100%; overflow: hidden;">
  <img
    src={imageUrl}
    alt={node.alt || ""}
    loading="lazy"
    style="max-width: 100%; width: 100%; height: auto; display: block;"
    class="rounded-lg shadow-md"
  />
  {node.alt && (
    <figcaption class="text-sm text-center text-gray-500 mt-2 italic">
      {node.alt}
    </figcaption>
  )}
</figure>
